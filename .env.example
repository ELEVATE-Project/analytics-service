# Example .env file for analytics_service

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=analytics.ingestion.raw
KAFKA_GROUP_ID=analytics-ingestion-group

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/temporal
RESET_DB=false

# Orchestration Mode: 'real-time' or 'batch'
PROCESSING_MODE=real-time
BATCH_SCHEDULE_CRON=0 20 * * *

# Temporal Configuration
TEMPORAL_HOST=localhost:7233
TEMPORAL_QUEUE=analytics-processing-queue

# LLM / OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60

# Scoped Ingestion Pipeline Configurations (JSON strings)
PROCESS_CONFIG_STORY=[{"name": "pii_and_abusive_language_detection", "columns": ["title", "objective", "challenges", "actionSteps", "impact", "blurb", "content"]}, {"name": "thematic_classification", "columns": ["objective"]}, {"name": "image_blur", "columns": ["imageUrls"]}]
PROCESS_CONFIG_DISCUSSION=[{"name": "pii_and_abusive_language_detection", "columns": ["title","challenges", "solutions"]}, {"name": "thematic_classification", "columns": ["challenges"]},{"name": "image_blur", "columns": ["imageUrls"]}]

# Thematic Classification Configuration
# Minimum word count for a statement to be classified (below this → Unknown/Unclear)
MINIMUM_THEME_WORD_COUNT=5
# Delimiter used to split discussion-type cells into separate statements
THEMATIC_STATEMENT_DELIMITER=|
# Local sentence-transformer model for embedding-based classification
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
# Cosine similarity threshold for local embedding match (Step 6)
SIMILARITY_SCORE_THRESHOLD=0.65
# LLM confidence score threshold on 0.0-1.0 scale (Step 8; 0.8 = "8 out of 10")
LLM_CONFIDENCE_SCORE_THRESHOLD=0.8

HF_TOKEN=huggingface_token


##GCP CREDENTIALS 
TYPE=service_account
PROJECT_ID=dev-sg-dashboard
PRIVATE_KEY_ID=dev-sg-dashboard
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nM"
CLIENT_EMAIL="sl.gcpserviceaccout.com"
AUTH_URI=https://accounts.google.com/o/oauth2/auth
TOKEN_URI=https://oauth2.googleapis.com/token
AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account-name%40your-project-id.iam.gserviceaccount.com
UNIVERSE_DOMAIN=googleapis.com
BUCKET_NAME=dev-sg-dashboard
CLIENT_ID=1216243614141746
GCP_BLOB_PREFIX=test_blurred_images