# Example .env file for analytics_service

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=analytics.ingestion.raw
KAFKA_TOPIC_INGESTION_DLQ=analytics.ingestion.raw.dlq
KAFKA_GROUP_ID=analytics-ingestion-group

# Deployment environment: 'production' (default/safe) or 'development'.
# Must be 'development' for RESET_DB=true to actually take effect.
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/temporal
RESET_DB=false

# Orchestration Mode: 'real-time' or 'batch'
PROCESSING_MODE=real-time
BATCH_SCHEDULE_CRON=0 20 * * *
BATCH_SIZE=100

# Temporal Configuration
TEMPORAL_HOST=localhost:7233
TEMPORAL_QUEUE=analytics-processing-queue

# LLM / OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60

# Story Rating Configuration
# Max characters of extracted PDF text sent to the LLM for story rating
MAX_PDF_TEXT_CHARS=40000

# Kafka ingestion-time field validation schemas (JSON strings). Any Kafka event
# missing/null/empty a "required" path is rejected and routed to the DLQ topic
# instead of being ingested. See app/kafka/consumer.py's _validate_ingestion_schema.
STORY_KAFKA_SCHEMA={"create": {"required": ["submissionId", "submissionType", "sessionId", "tenantCode", "eventType", "eventPublishedAt", "tags.state", "tags.district", "tags.organization", "tags.programId", "tags.programName", "tags.leaderCategoryId", "tags.leaderCategoryName", "data.title", "data.designation", "data.submissionDate", "data.pdfUrls.original", "data.pdfUrls.masked", "data.transcriptLink", "data.challenges", "data.objective", "data.actionSteps", "data.impact", "data.duration", "data.blurb", "data.content"], "optional": ["data.imageUrls"]}, "update": {"required": ["submissionId", "submissionType", "sessionId", "tenantCode", "eventType", "eventPublishedAt"], "newValuesNoEmpty": true}, "delete": {"required": ["submissionId", "submissionType", "sessionId", "tenantCode", "eventType", "eventPublishedAt"]}}
DISCUSSION_KAFKA_SCHEMA={"create": {"required": ["submissionId", "submissionType", "sessionId", "tenantCode", "eventType", "eventPublishedAt", "tags.state", "tags.district", "tags.organization", "tags.programId", "tags.programName", "tags.leaderCategoryId", "tags.leaderCategoryName", "data.title", "data.designation", "data.submissionDate", "data.pdfUrls.original", "data.pdfUrls.masked", "data.transcriptLink", "data.challenges", "data.solutions", "data.participantsData"], "optional": ["data.author", "data.language", "data.imageUrls"]}, "update": {"required": ["submissionId", "submissionType", "sessionId", "tenantCode", "eventType", "eventPublishedAt"], "newValuesNoEmpty": true}, "delete": {"required": ["submissionId", "submissionType", "sessionId", "tenantCode", "eventType", "eventPublishedAt"]}}

# Scoped Ingestion Pipeline Configurations (JSON strings)
# Each step optionally accepts "llm_model" / "max_tokens" / "llm_timeout_seconds" to override
# OPENROUTER_MODEL / LLM_MAX_TOKENS / LLM_TIMEOUT_SECONDS for that step only (falls back to the
# globals above when omitted). Not applicable to "image_blur", which makes no LLM call.
PROCESS_CONFIG_STORY=[{"name":"pii_and_abusive_language_detection","columns":["title","objective","challenges","actionSteps","impact","blurb","content"],"llm_model":"google/gemini-2.5-flash-lite","max_tokens":2048,"llm_timeout_seconds":60},{"name":"thematic_classification","columns":["objective"],"llm_model":"kwaipilot/kat-coder-air-v2.5","max_tokens":2048,"llm_timeout_seconds":60},{"name":"image_blur","columns":["imageUrls"]},{"name":"story_rating","llm_model":"x-ai/grok-4.5","max_tokens":2048,"llm_timeout_seconds":60}]
PROCESS_CONFIG_DISCUSSION=[{"name":"pii_and_abusive_language_detection","columns":["title","challenges","solutions"],"llm_model":"google/gemini-2.5-flash-lite","max_tokens":2048,"llm_timeout_seconds":60},{"name":"thematic_classification","columns":["challenges"],"llm_model":"google/gemini-2.5-flash-lite","max_tokens":2048,"llm_timeout_seconds":60},{"name":"image_blur","columns":["imageUrls"]}]

# Thematic Classification Configuration
# Minimum word count for a statement to be classified (below this → Unknown/Unclear)
MINIMUM_THEME_WORD_COUNT=5
# Local sentence-transformer model for embedding-based classification
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
# Cosine similarity threshold for local embedding match (Step 6)
SIMILARITY_SCORE_THRESHOLD=0.65
# LLM confidence score threshold on 0.0-1.0 scale (Step 8; 0.8 = "8 out of 10")
LLM_CONFIDENCE_SCORE_THRESHOLD=0.8

